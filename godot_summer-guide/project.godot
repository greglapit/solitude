config_version=5

[application]

config/name="godot_summer-guide"
run/main_scene="uid://0tk7al8pp3w"
config/features=PackedStringArray("4.5", "Forward Plus")
config/icon="res://z_August Work/Common/icon.svg"

[autoload]

